{{ 'pocketprint.css' | asset_url | stylesheet_tag }}

<section class="pp-how pp-page" id="{{ section.settings.section_id }}">
  <div class="pp-container">
    <div class="pp-how-header" data-pp-reveal>
      <div class="pp-eyebrow">{{ section.settings.eyebrow }}</div>
      <h2 class="pp-section-title">{{ section.settings.title | replace: '[i]', '<span class="pp-ital">' | replace: '[/i]', '</span>' }}</h2>
    </div>

    <div class="pp-how-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'step' -%}
          <div class="pp-how-step" {{ block.shopify_attributes }} data-pp-reveal>
            <div class="pp-how-num">0{{ forloop.index }}</div>
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.description }}</p>
            <div class="pp-how-icon">
              {%- case forloop.index -%}
                {%- when 1 -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M7 16l5-13 5 13M7 8l10 8M17 8L7 16"/></svg>
                {%- when 2 -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="M21 15l-5-5L5 21"/></svg>
                {%- when 3 -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 9V2h12v7M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
              {%- endcase -%}
              <span>{{ block.settings.meta }}</span>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "PocketPrint — How It Works",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "section_id",
      "label": "Section anchor ID",
      "default": "how"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "03 · Process"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title (use [i]...[/i] for italic)",
      "default": "From idea to [i]paper[/i] in three taps."
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Step title",
          "default": "Pair"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Open the PocketPrint app and connect via Bluetooth."
        },
        {
          "type": "text",
          "id": "meta",
          "label": "Meta label",
          "default": "Bluetooth 5.0"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PocketPrint — How It Works",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "Pair",
            "description": "Open the PocketPrint app and connect via Bluetooth. Setup takes less than 8 seconds — no accounts, no friction.",
            "meta": "Bluetooth 5.0"
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Pick",
            "description": "Choose a photo, write a note, scan a doc, or grab a meme. Apply filters, frames, retro effects — whatever fits the mood.",
            "meta": "iOS · Android"
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Print",
            "description": "Hit print. In 6 seconds, you're holding a tangible piece of your day. No ink. No mess. Just paper, in your hand.",
            "meta": "6 seconds"
          }
        }
      ]
    }
  ],
  "max_blocks": 3
}
{% endschema %}
